{
  "name": "tabby-status",
  "version": "0.1.4",
  "description": "System status side panel for Tabby SSH sessions",
  "author": "local",
  "keywords": [
    "tabby-plugin"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "node node_modules/webpack/bin/webpack.js --mode production",
    "dev": "node node_modules/webpack/bin/webpack.js --mode development --watch",
    "pack:plugin": "npm run build && node scripts/pack-plugin.mjs",
    "install-local": "npm run build && node scripts/install-local.mjs",
    "test:smoke": "npm run build && node tests/smoke.mjs"
  },
  "files": [
    "dist"
  ],
  "dependencies": {},
  "devDependencies": {
    "@angular/common": "^15.0.0",
    "@angular/core": "^15.0.0",
    "rxjs": "^7.8.0",
    "tabby-core": "1.0.231-nightly.0",
    "tabby-terminal": "1.0.231-nightly.0",
    "ts-loader": "^9.5.1",
    "typescript": "4.9.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "peerDependencies": {
    "tabby-core": "*",
    "tabby-terminal": "*"
  }
}
